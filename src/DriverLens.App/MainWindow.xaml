<ui:FluentWindow x:Class="DriverLens.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:DriverLens.App"
                 xmlns:core="clr-namespace:DriverLens.Core;assembly=DriverLens.Core"
                 Title="DriverLens - Open Source Driver Manager"
                 Width="1000"
                 Height="650"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Modern Fluent TitleBar -->
        <ui:TitleBar Grid.Row="0"
                     Title="DriverLens"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Header>
                <TextBlock Text="DriverLens — Phase 1 Scanner" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#888888" FontSize="11" />
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="24,12,24,24">
            <!-- Loading Indicator -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="50" Height="50" />
                    <TextBlock Text="Scanning hardware and driver index..." 
                               FontSize="16" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Center" 
                               Foreground="#CCCCCC" />
                </StackPanel>
            </Grid>

            <!-- Device list display (Hidden while loading) -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Hardware Scan &amp; Driver Match" FontSize="24" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="This is a read-only list showing current drivers and matching index candidates. No changes will be made to your system." 
                               FontSize="13" Foreground="#999999" Margin="0,4,0,0" />
                    
                    <Border Margin="0,8,0,0" Padding="12,6" CornerRadius="4" Background="#11FFFFFF" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#88FFFFFF" />
                            <TextBlock Text="{Binding SyncStatusText}" FontSize="12" Foreground="#88FFFFFF" VerticalAlignment="Center" FontWeight="Medium" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Scrollable list of grouped devices -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Focusable="False">
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:DeviceGroupViewModel}">
                                <StackPanel Margin="0,0,0,24">
                                    <!-- Group Header -->
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#33FFFFFF" Padding="0,4,0,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DeviceClass}" 
                                                       FontSize="18" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="#4A90E2" />
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Devices.Count, StringFormat='{}{0} devices'}" 
                                                       FontSize="12" 
                                                       VerticalAlignment="Center" 
                                                       Foreground="#88FFFFFF" />
                                        </Grid>
                                    </Border>

                                    <!-- Group Devices -->
                                    <ItemsControl ItemsSource="{Binding Devices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:DeviceItemViewModel}">
                                                <ui:CardExpander Margin="0,2,0,2" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Padding="16,12">
                                                    <ui:CardExpander.Header>
                                                        <Grid HorizontalAlignment="Stretch" Margin="0,0,16,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding FriendlyName}" 
                                                                       FontSize="14" 
                                                                       FontWeight="Medium" 
                                                                       Foreground="White"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" />
                                                            <!-- Status Badge -->
                                                            <ui:Badge Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                <ui:Badge.Style>
                                                                    <Style TargetType="ui:Badge">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static core:MatchStatus.UpToDate}">
                                                                                <Setter Property="Appearance" Value="Success" />
                                                                                <Setter Property="Content" Value="Up to Date" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static core:MatchStatus.UpdateAvailable}">
                                                                                <Setter Property="Appearance" Value="Primary" />
                                                                                <Setter Property="Content" Value="Update Available" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static core:MatchStatus.NoSafeCandidate}">
                                                                                <Setter Property="Appearance" Value="Secondary" />
                                                                                <Setter Property="Content" Value="No Safe Candidate" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static core:MatchStatus.NotInIndex}">
                                                                                <Setter Property="Appearance" Value="Secondary" />
                                                                                <Setter Property="Content" Value="Not In Index" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ui:Badge.Style>
                                                            </ui:Badge>
                                                        </Grid>
                                                    </ui:CardExpander.Header>

                                                    <!-- Details Content -->
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Left Column: Current Driver Info -->
                                                        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#22FFFFFF" Padding="0,0,16,0">
                                                            <StackPanel>
                                                                <TextBlock Text="CURRENT DRIVER" FontSize="11" FontWeight="Bold" Foreground="#88FFFFFF" Margin="0,0,0,6" />
                                                                <TextBlock Text="{Binding CurrentDriverText}" FontSize="13" Foreground="#DDFFFFFF" TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding Device.DeviceInstanceId, StringFormat='ID: {0}'}" FontSize="11" Foreground="#55FFFFFF" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Right Column: Proposed Driver Info -->
                                                        <Border Grid.Column="1" Padding="16,0,0,0">
                                                            <StackPanel>
                                                                <TextBlock Text="PROPOSED DRIVER CANDIDATE" FontSize="11" FontWeight="Bold" Foreground="#88FFFFFF" Margin="0,0,0,6" />
                                                                <Grid>
                                                                    <!-- Not in Index yet view -->
                                                                    <TextBlock Text="No proposed candidate (not in index yet)" 
                                                                               FontSize="13" 
                                                                               FontStyle="Italic" 
                                                                               Foreground="#66FFFFFF">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsNotInIndex}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    
                                                                    <!-- Proposed candidate view -->
                                                                    <StackPanel>
                                                                        <StackPanel.Style>
                                                                            <Style TargetType="StackPanel">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasProposedDriver}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </StackPanel.Style>
                                                                        <TextBlock Text="{Binding ProposedDriverText}" FontSize="13" Foreground="#DDFFFFFF" FontWeight="SemiBold" />
                                                                        
                                                                        <Grid Margin="0,8,0,0">
                                                                            <!-- 1. "Обновить" Button -->
                                                                            <ui:Button Content="Обновить" 
                                                                                       Icon="ArrowDownload24" 
                                                                                       Appearance="Primary"
                                                                                       Command="{Binding DataContext.UpdateDeviceCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                                                       CommandParameter="{Binding}"
                                                                                       Height="32">
                                                                                <ui:Button.Style>
                                                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding InstallSucceeded}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static core:MatchStatus.UpToDate}">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </ui:Button.Style>
                                                                            </ui:Button>

                                                                            <!-- 2. Installation Progress View -->
                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                <StackPanel.Style>
                                                                                    <Style TargetType="StackPanel">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </StackPanel.Style>
                                                                                <ui:ProgressRing IsIndeterminate="True" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                                                <TextBlock Text="{Binding InstallProgressText}" FontSize="12" Foreground="#88FFFFFF" VerticalAlignment="Center" />
                                                                            </StackPanel>

                                                                            <!-- 3. Success Message -->
                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                <StackPanel.Style>
                                                                                    <Style TargetType="StackPanel">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding InstallSucceeded}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </StackPanel.Style>
                                                                                <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="Green" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                                                <TextBlock Text="Обновлен успешно" Foreground="Green" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                                            </StackPanel>

                                                                            <!-- 4. Failure Message -->
                                                                            <StackPanel VerticalAlignment="Center">
                                                                                <StackPanel.Style>
                                                                                    <Style TargetType="StackPanel">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding InstallFailed}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </StackPanel.Style>
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <ui:SymbolIcon Symbol="ErrorCircle24" Foreground="Red" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                                                    <TextBlock Text="Ошибка" Foreground="Red" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                                                    <ui:Button Content="Детали" 
                                                                                               Appearance="Transparent" 
                                                                                               Padding="4,2" 
                                                                                               Margin="8,0,0,0" 
                                                                                               FontSize="11" 
                                                                                               Click="ToggleDetails_Click" />
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                        </Grid>

                                                                        <!-- Details display -->
                                                                        <Border BorderThickness="1" 
                                                                                BorderBrush="#33FF0000" 
                                                                                Background="#11FF0000" 
                                                                                CornerRadius="4" 
                                                                                Padding="8" 
                                                                                Margin="0,8,0,0">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding InstallFailed}" Value="True" />
                                                                                                <Condition Binding="{Binding ShowDetailsExpanded}" Value="True" />
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </MultiDataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                                                                <TextBlock Text="{Binding InstallDetails}" 
                                                                                           FontSize="11" 
                                                                                           Foreground="#FF8888" 
                                                                                           TextWrapping="Wrap" 
                                                                                           FontFamily="Consolas" />
                                                                            </ScrollViewer>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Grid>
                                                                
                                                                <!-- Match Reason and Class Warning -->
                                                                <TextBlock Text="Status Details:" FontSize="11" FontWeight="Bold" Foreground="#66FFFFFF" Margin="0,12,0,2" />
                                                                <TextBlock Text="{Binding Reason}" FontSize="12" Foreground="#4A90E2" TextWrapping="Wrap" />
                                                                
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </ui:CardExpander>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
        
        <!-- ContentDialogHost for ContentDialogs -->
        <ui:ContentDialogHost x:Name="RootContentDialogPresenter" Grid.Row="0" Grid.RowSpan="2" />
    </Grid>
</ui:FluentWindow>
